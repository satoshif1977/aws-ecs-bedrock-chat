project    = "ecs-bedrock-chat"
env        = "dev"
aws_region = "ap-northeast-1"

# ECR に push したイメージ URI（<account_id>.dkr.ecr.<region>.amazonaws.com/<repo>:latest）
ecr_image_uri = "<YOUR_ACCOUNT_ID>.dkr.ecr.ap-northeast-1.amazonaws.com/bedrock-chat:latest"

# Fargate リソース設定（0.25 vCPU / 0.5 GB）
task_cpu    = 256
task_memory = 512

# Streamlit デフォルトポート
container_port = 8501

# CloudWatch Logs 保持期間
log_retention_days = 7

# ECS Service: 起動タスク数（検証時は 1 で最小コスト）
desired_count = 1
